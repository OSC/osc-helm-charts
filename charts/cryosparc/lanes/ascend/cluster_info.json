{
    "name": "ascend",
    "worker_bin_path": "REPLACE_ME_WORKER_BIN_PATH",
    "send_cmd_tpl": "{{ command }}",
    "qsub_cmd_tpl": "sbatch -M ascend {{ script_path_abs }}",
    "qstat_cmd_tpl": "squeue -M ascend -j {{ cluster_job_id }}",
    "qdel_cmd_tpl": "scancel -M ascend {{ cluster_job_id }}",
    "qinfo_cmd_tpl": "sinfo -M ascend",
    "cache_path": "/tmp"
}
